const HospitalDetail = () => {
  const { id } = useParams();
  const [searchParams] = useSearchParams();
  const selectedProcedure = searchParams.get("procedure");
  const selectedSpecialty = searchParams.get("specialty");
  
  const [hospital, setHospital] = useState<any>(null);
  const [activeTab, setActiveTab] = useState<string>("");
  const [procedureData, setProcedureData] = useState<any>(null);
  const [infoTab, setInfoTab] = useState("introduction");

  useEffect(() => {
    window.scrollTo(0, 0);
    
    // Find the hospital by ID
    const foundHospital = hospitalData.find(h => h.id === parseInt(id || "0", 10));
    
    if (foundHospital) {
      setHospital(foundHospital);
      document.title = `${foundHospital.name} | MedChina`;
      
      // Set active tab based on the selected specialty or default to first department
      if (selectedSpecialty && foundHospital.departments.some(dept => dept.name === selectedSpecialty)) {
        setActiveTab(selectedSpecialty);
      } else if (foundHospital.departments.length > 0) {
        setActiveTab(foundHospital.departments[0].name);
      }

      // Set procedure data if available
      if (selectedProcedure && procedureDetails[selectedProcedure]) {
        setProcedureData(procedureDetails[selectedProcedure]);
      }
    }
  }, [id, selectedSpecialty, selectedProcedure]);

  if (!hospital) {
    return (
      <div className="min-h-screen">
        <TopUtilityBar />
        <MainNavigation />
        <div className="container mx-auto px-4 py-16 text-center">
          <Hospital className="mx-auto h-16 w-16 text-gray-400 mb-4" />
          <h1 className="text-2xl font-bold text-gray-900 mb-2">Hospital Not Found</h1>
          <p className="text-gray-600">The hospital you're looking for doesn't exist or has been removed.</p>
        </div>
        <Footer />
      </div>
    );
  }

  return (
    <div className="min-h-screen">
      <TopUtilityBar />
      <MainNavigation />
      
      <div className="bg-gray-50 py-8">
        <div className="container mx-auto px-4">
          {/* Hospital header */}
          <div className="bg-white rounded-lg shadow-md overflow-hidden mb-6">
            <div className="relative h-64 w-full">
              <img 
                src={hospital.image} 
                alt={hospital.name} 
                className="h-full w-full object-cover"
              />
              <div className="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent flex items-end">
                <div className="p-6 text-white">
                  <h1 className="text-3xl font-bold mb-2">{hospital.name}</h1>
                  <div className="flex items-center gap-2 mb-2">
                    <div className="flex">
                      {Array.from({ length: 5 }).map((_, i) => (
                        <Star
                          key={i}
                          className={`h-5 w-5 ${
                            i < Math.floor(hospital.rating) ? "text-yellow-400 fill-yellow-400" : "text-gray-300"
                          }`}
                        />
                      ))}
                    </div>
                    <span className="text-lg font-semibold">{hospital.rating.toFixed(1)}</span>
                  </div>
                  <div className="flex flex-wrap gap-2">
                    {hospital.isJCIAccredited && (
                      <HoverCard>
                        <HoverCardTrigger asChild>
                          <Badge variant="default" className="bg-blue-600 cursor-help">JCI Accredited</Badge>
                        </HoverCardTrigger>
                        <HoverCardContent className="w-80 text-sm">
                          <p>{accreditationInfo["JCI Accredited"]}</p>
                          <div className="mt-2">
                            <a 
                              href="https://en.wikipedia.org/wiki/Joint_Commission_International" 
                              target="_blank" 
                              rel="noopener noreferrer"
                              className="text-blue-600 hover:text-blue-800 flex items-center gap-1 text-xs"
                            >
                              Learn more <ExternalLink size={12} />
                            </a>
                          </div>
                        </HoverCardContent>
                      </HoverCard>
                    )}
                    {hospital.accreditations?.map((accreditation: string, index: number) => (
                      <HoverCard key={index}>
                        <HoverCardTrigger asChild>
                          <Badge variant="outline" className="border-green-500 text-green-600 bg-white/90 cursor-help">
                            {accreditation}
                          </Badge>
                        </HoverCardTrigger>
                        <HoverCardContent className="w-80 text-sm">
                          <p>{accreditationInfo[accreditation] || `${accreditation} is a healthcare quality standard.`}</p>
                          <div className="mt-2">
                            <a 
                              href={`https://en.wikipedia.org/wiki/${encodeURIComponent(accreditation.replace(" ", "_"))}`}
                              target="_blank" 
                              rel="noopener noreferrer"
                              className="text-blue-600 hover:text-blue-800 flex items-center gap-1 text-xs"
                            >
                              Learn more <ExternalLink size={12} />
                            </a>
                          </div>
                        </HoverCardContent>
                      </HoverCard>
                    ))}
                  </div>
                </div>
              </div>
            </div>
            <div className="p-6">
              {/* Basic stats */}
              <div className="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
                <div>
                  <p className="text-gray-500 text-sm">Average Wait Time</p>
                  <p className="font-medium">{hospital.waitTime}</p>
                </div>
                <div>
                  <p className="text-gray-500 text-sm">Average Cost Range</p>
                  <p className="font-medium">{hospital.cost}</p>
                </div>
                <div>
                  <p className="text-gray-500 text-sm">Annual Cases</p>
                  <p className="font-medium">{hospital.annualCases}+ procedures</p>
                </div>
              </div>

              {/* Hospital Information Tabs */}
              <Tabs value={infoTab} onValueChange={setInfoTab} className="w-full mb-6">
                <TabsList className="grid grid-cols-3 mb-2">
                  <TabsTrigger value="introduction">Introduction</TabsTrigger>
                  <TabsTrigger value="travel">Travel & Convenience</TabsTrigger>
                  <TabsTrigger value="accreditations">Accreditations</TabsTrigger>
                </TabsList>

                {/* Introduction Tab */}
                <TabsContent value="introduction" className="border rounded-md p-4 bg-gray-50">
                  <div className="mb-6">
                    <h2 className="text-xl font-semibold mb-3">About {hospital.name}</h2>
                    <p className="text-gray-700 leading-relaxed">{hospital.introduction}</p>
                  </div>
                  
                  {/* Address */}
                  <div className="flex items-start gap-2">
                    <MapPin className="h-5 w-5 text-blue-600 mt-1 flex-shrink-0" />
                    <div>
                      <h3 className="font-medium">Hospital Address</h3>
                      <p className="text-gray-700">{hospital.address}</p>
                    </div>
                  </div>
                </TabsContent>

                {/* Travel & Convenience Tab */}
                <TabsContent value="travel" className="border rounded-md p-4 bg-gray-50">
                  {hospital.travelInfo && (
                    <div>
                      <h2 className="text-xl font-semibold mb-3">Travel & Convenience</h2>
                      <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div className="bg-white p-3 rounded shadow-sm">
                          <h3 className="font-medium text-blue-700">Airport Access</h3>
                          <p className="text-gray-700">{hospital.travelInfo.airport}</p>
                        </div>
                        <div className="bg-white p-3 rounded shadow-sm">
                          <h3 className="font-medium text-blue-700">Public Transportation</h3>
                          <p className="text-gray-700">{hospital.travelInfo.metro}</p>
                        </div>
                        <div className="bg-white p-3 rounded shadow-sm">
                          <h3 className="font-medium text-blue-700">Accommodation</h3>
                          <p className="text-gray-700">{hospital.travelInfo.accommodation}</p>
                        </div>
                        <div className="bg-white p-3 rounded shadow-sm">
                          <h3 className="font-medium text-blue-700">Visa Assistance</h3>
                          <p className="text-gray-700">{hospital.travelInfo.visa}</p>
                        </div>
                      </div>
                    </div>
                  )}
                </TabsContent>

                {/* Accreditations Tab */}
                <TabsContent value="accreditations" className="border rounded-md p-4 bg-gray-50">
                  <div>
                    <h2 className="text-xl font-semibold mb-3">Hospital Accreditations</h2>
                    <div className="flex flex-wrap gap-3">
                      {hospital.isJCIAccredited && (
                        <div className="border border-blue-200 bg-white px-3 py-2 rounded-md flex items-center gap-2 shadow-sm">
                          <CheckCircle2 className="h-5 w-5 text-blue-600" />
                          <div>
                            <h3 className="font-medium">Joint Commission International (JCI)</h3>
                            <p className="text-xs text-gray-600">Global gold standard in healthcare quality</p>
                          </div>
                        </div>
                      )}
                      {hospital.accreditations?.map((accreditation: string, index: number) => (
                        <div key={index} className="border border-green-200 bg-white px-3 py-2 rounded-md flex items-center gap-2 shadow-sm">
                          <CheckCircle2 className="h-5 w-5 text-green-600" />
                          <div>
                            <h3 className="font-medium">{accreditation}</h3>
                            <p className="text-xs text-gray-600">
                              {accreditationInfo[accreditation]?.split('.')[0] || 'Healthcare quality certification'}
                            </p>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                </TabsContent>
              </Tabs>

              <div className="flex justify-end">
                <a 
                  href={hospital.website} 
                  target="_blank" 
                  rel="noopener noreferrer"
                  className="text-blue-600 hover:text-blue-800 flex items-center gap-1 text-sm"
                >
                  Visit Hospital Website <ExternalLink size={16} />
                </a>
              </div>
            </div>
          </div>

          {/* Department tabs and procedures */}
          <div className="bg-white rounded-lg shadow-md p-6 mb-8">
            <h2 className="text-2xl font-bold mb-6">Medical Departments</h2>
            
            <Tabs value={activeTab} onValueChange={setActiveTab} className="w-full">
              <TabsList className="mb-6 w-full flex overflow-x-auto space-x-2 border-b pb-1">
                {hospital.departments.map((dept: any) => (
                  <TabsTrigger 
                    key={dept.name} 
                    value={dept.name}
                    className={`px-4 py-2 ${
                      activeTab === dept.name 
                        ? "border-b-2 border-blue-600 text-blue-700" 
                        : "text-gray-600"
                    }`}
                  >
                    {dept.name}
                  </TabsTrigger>
                ))}
              </TabsList>
              
              {hospital.departments.map((dept: any) => (
                <TabsContent key={dept.name} value={dept.name}>
                  <h3 className="text-xl font-semibold mb-4">{dept.name} Procedures</h3>
                  
                  {/* Procedure list */}
                  <div className="grid grid-cols-1 gap-4 mb-8">
                    {dept.procedures.map((proc: any) => {
                      const isSelected = selectedProcedure === proc.name && dept.name === selectedSpecialty;
                      const hasProcedureDetails = procedureDetails[proc.name] !== undefined;
                      
                      return (
                        <div 
                          key={proc.name}
                          className={`p-4 border rounded-md transition-colors ${
                            isSelected 
                              ? "bg-blue-50 border-blue-300" 
                              : "bg-white hover:bg-gray-50"
                          }`}
                        >
                          <div className="flex justify-between items-center">
                            <div>
                              <h4 className="text-lg font-medium flex items-center gap-2">
                                {isSelected && (
                                  <Badge variant="default" className="bg-blue-600">Current Selection</Badge>
                                )}
                                {proc.name}
                              </h4>
                              <div className="grid grid-cols-2 gap-4 mt-2">
                                <div>
                                  <p className="text-gray-500 text-sm">Wait Time</p>
                                  <p className="font-medium">{proc.waitTime}</p>
                                </div>
                                <div>
                                  <p className="text-gray-500 text-sm">Estimated Cost</p>
                                  <p className="font-medium">{proc.cost}</p>
                                </div>
                              </div>
                            </div>
                            {hasProcedureDetails && (
                              <a 
                                href={`/hospital/${id}?specialty=${dept.name}&procedure=${encodeURIComponent(proc.name)}`}
                                className={`px-4 py-2 rounded-md text-sm ${
                                  isSelected 
                                    ? "bg-blue-600 text-white" 
                                    : "bg-gray-100 text-gray-700 hover:bg-gray-200"
                                }`}
                              >
                                {isSelected ? "Currently Viewing" : "View Details"}
                              </a>
                            )}
                          </div>
                        </div>
                      );
                    })}
                  </div>
                  
                  {/* Selected procedure details */}
                  {selectedProcedure && selectedSpecialty === dept.name && procedureData && (
                    <div className="mt-8">
                      <div className="border-t border-b py-4 mb-6">
                        <h2 className="text-2xl font-bold text-blue-700 flex items-center">
                          {selectedProcedure} Details
                        </h2>
                      </div>
                      
                      <div className="space-y-8">
                        {/* Overview */}
                        <Card>
                          <CardHeader>
                            <CardTitle className="flex items-center gap-2">
                              <FileText className="h-5 w-5" /> Procedure Overview
                            </CardTitle>
                          </CardHeader>
                          <CardContent>
                            <p>{procedureData.overview}</p>
                          </CardContent>
                        </Card>
                        
                        {/* Price comparison */}
                        <Card>
                          <CardHeader>
                            <CardTitle>Price Comparison</CardTitle>
                            <CardDescription>See how much you can save compared to US prices</CardDescription>
                          </CardHeader>
                          <CardContent>
                            <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                              <div className="p-4 border rounded-md bg-blue-50">
                                <p className="text-sm text-gray-500 mb-1">Cost in China</p>
                                <p className="text-2xl font-bold text-blue-700">{procedureData.priceComparison.china}</p>
                              </div>
                              <div className="p-4 border rounded-md bg-gray-50">
                                <p className="text-sm text-gray-500 mb-1">Cost in US</p>
                                <p className="text-2xl font-bold text-gray-700">{procedureData.priceComparison.us}</p>
                              </div>
                            </div>
                          </CardContent>
                        </Card>
                        
                        {/* Doctor profiles */}
                        <Card>
                          <CardHeader>
                            <CardTitle>Doctor Profiles</CardTitle>
                            <CardDescription>Meet our specialists for {selectedProcedure}</CardDescription>
                          </CardHeader>
                          <CardContent>
                            <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                              {procedureData.doctors.map((doctor, index) => (
                                <div key={index} className="flex gap-4 p-4 border rounded-md">
                                  <img 
                                    src={doctor.image} 
                                    alt={doctor.name} 
                                    className="h-20 w-20 object-cover rounded-full"
                                  />
                                  <div>
                                    <h4 className="font-semibold text-lg">{doctor.name}</h4>
                                    <p className="text-blue-700">{doctor.title}</p>
                                    <p className="text-sm text-gray-600">{doctor.experience} experience</p>
                                    <p className="text-sm text-gray-600">
                                      <span className="font-medium">Education:</span> {doctor.education}
                                    </p>
                                    <p className="text-sm text-blue-600 mt-1">{doctor.specialization}</p>
                                  </div>
                                </div>
                              ))}
                            </div>
                          </CardContent>
                        </Card>
                        
                        {/* Statistics */}
                        <Card>
                          <CardHeader>
                            <CardTitle>Procedure Statistics</CardTitle>
                            <CardDescription>Key performance metrics for {selectedProcedure} at {hospital.name}</CardDescription>
                          </CardHeader>
                          <CardContent>
                            <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
                              <div className="p-4 bg-gray-50 rounded-md text-center">
                                <p className="text-gray-500 text-sm">Annual Cases</p>
                                <p className="text-2xl font-bold text-blue-700">{procedureData.statistics.annualCases}</p>
                              </div>
                              <div className="p-4 bg-green-50 rounded-md text-center">
                                <p className="text-gray-500 text-sm">Success Rate</p>
                                <p className="text-2xl font-bold text-green-700">{procedureData.statistics.successRate}</p>
                              </div>
                              <div className="p-4 bg-amber-50 rounded-md text-center">
                                <p className="text-gray-500 text-sm">Complication Rate</p>
                                <p className="text-2xl font-bold text-amber-700">{procedureData.statistics.complicationRate}</p>
                              </div>
                              <div className="p-4 bg-purple-50 rounded-md text-center">
                                <p className="text-gray-500 text-sm">Readmission Rate</p>
                                <p className="text-2xl font-bold text-purple-700">{procedureData.statistics.readmissionRate}</p>
                              </div>
                              <div className="p-4 bg-red-50 rounded-md text-center">
                                <p className="text-gray-500 text-sm">Mortality Rate</p>
                                <p className="text-2xl font-bold text-red-700">{procedureData.statistics.mortalityRate}</p>
                              </div>
                            </div>
                          </CardContent>
                        </Card>
                        
                        {/* Videos */}
                        <Card>
                          <CardHeader>
                            <CardTitle className="flex items-center gap-2">
                              <Video className="h-5 w-5" /> Related Videos
                            </CardTitle>
                          </CardHeader>
                          <CardContent>
                            <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                              {procedureData.videos.map((video, index) => (
                                <a 
                                  key={index} 
                                  href={video.url} 
                                  target="_blank" 
                                  rel="noopener noreferrer"
                                  className="group"
                                >
                                  <div className="relative rounded-md overflow-hidden">
                                    <img 
                                      src={video.thumbnail} 
                                      alt={video.title} 
                                      className="w-full h-48 object-cover group-hover:opacity-90 transition-opacity"
                                    />
                                    <div className="absolute inset-0 bg-black/30 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                                      <Video className="h-12 w-12 text-white" />
                                    </div>
                                  </div>
                                  <p className="mt-2 font-medium group-hover:text-blue-600 transition-colors">{video.title}</p>
                                </a>
                              ))}
                            </div>
                          </CardContent>
                        </Card>
                        
                        {/* FAQs */}
                        <Card>
                          <CardHeader>
                            <CardTitle>Frequently Asked Questions</CardTitle>
                            <CardDescription>Common questions about {selectedProcedure}</CardDescription>
                          </CardHeader>
                          <CardContent>
                            <Accordion type="single" collapsible className="w-full">
                              {procedureData.faqs.map((faq, index) => (
                                <AccordionItem key={index} value={`faq-${index}`}>
                                  <AccordionTrigger>{faq.question}</AccordionTrigger>
                                  <AccordionContent>
                                    <p className="text-gray-700">{faq.answer}</p>
                                  </AccordionContent>
                                </AccordionItem>
                              ))}
                            </Accordion>
                          </CardContent>
                        </Card>
                      </div>
                    </div>
                  )}
                </TabsContent>
              ))}
            </Tabs>
          </div>
        </div>
      </div>
      
      <Footer />
    </div>
  );
};

export default HospitalDetail;
