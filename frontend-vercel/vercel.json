{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "redirects": [
    {
      "source": "/en",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/en/:path*",
      "destination": "/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/patient/:path*",
      "destination": "https://crmapi.medicaltourismchina.health/api/patient/:path*"
    },
    {
      "source": "/api/v2/:path*",
      "destination": "https://crmapi.medicaltourismchina.health/api/v2/:path*"
    },
    {
      "source": "/api/v3/:path*",
      "destination": "https://crmapi.medicaltourismchina.health/api/v3/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
