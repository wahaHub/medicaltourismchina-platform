{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/patient/:path*",
      "destination": "https://crmapi.medicaltourismchina.health/api/patient/:path*"
    },
    {
      "source": "/api/v2/:path*",
      "destination": "https://crmapi.medicaltourismchina.health/api/v2/:path*"
    },
    {
      "source": "/api/v3/:path*",
      "destination": "https://crmapi.medicaltourismchina.health/api/v3/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
